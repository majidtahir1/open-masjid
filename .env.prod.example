# Production env file for the Docker compose stack. Copy to `.env` on the
# deploy host (NOT committed) and tighten permissions: `chmod 600 .env`.

# -----------------------------------------------------------------------------
# Postgres (inside-cluster; app reaches it by service name `db`)
# -----------------------------------------------------------------------------
POSTGRES_USER=openmasjid
POSTGRES_PASSWORD=CHANGE-ME-to-a-strong-random-password
POSTGRES_DB=openmasjid

# Database URI the app uses. Service name `db`, port 5432 (internal).
DATABASE_URI=postgres://openmasjid:CHANGE-ME-to-a-strong-random-password@db:5432/openmasjid

# -----------------------------------------------------------------------------
# Payload
# -----------------------------------------------------------------------------
# openssl rand -hex 32
PAYLOAD_SECRET=replace-with-32-byte-random-hex

# Public URL the site is served at (used for reset-password / preview links).
NEXT_PUBLIC_SERVER_URL=https://openmasjid.app

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@openmasjid.app
EMAIL_FROM_NAME=OpenMasjid

# -----------------------------------------------------------------------------
# Scheduled publishing cron (shared secret between app + cron sidecar)
# -----------------------------------------------------------------------------
# openssl rand -hex 32
CRON_SECRET=replace-with-another-32-byte-random-hex

# -----------------------------------------------------------------------------
# Media storage
# -----------------------------------------------------------------------------
# Host path that will be bind-mounted into the app container at
# /app/public/media. Point this at an NFS mount from TrueNAS for durable
# off-box storage with ZFS snapshots. Example:
#   MEDIA_PATH=/mnt/truenas/openmasjid-media
MEDIA_PATH=./media

# -----------------------------------------------------------------------------
# Network binding for the app's published port
# -----------------------------------------------------------------------------
# Default 0.0.0.0 publishes on every interface — required when NPM lives on
# another host on the LAN and proxies to http://<this-host-ip>:3000.
# Set to 127.0.0.1 if NPM runs on the same host (only loopback access needed).
APP_BIND=0.0.0.0
