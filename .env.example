DATABASE_URI=postgres://postgres:postgres@localhost:5433/openmasjid
PAYLOAD_SECRET=replace-with-a-32-byte-random-hex-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Resolve dev tenant when using bare http://localhost:3000 (no subdomain)
DEV_TENANT_SLUG=icp

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Leaving RESEND_API_KEY unset makes Payload log outgoing emails to the console
# — fine for local dev. Set it to send real emails (forgot-password, invites).
#
# Get an API key at https://resend.com — free tier is 100 emails/day, 3000/mo.
# In production, verify your domain in Resend before using a custom from-address.
# In dev you can use "onboarding@resend.dev" (works without verification).

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM_ADDRESS=noreply@openmasjid.app
# EMAIL_FROM_NAME=OpenMasjid

# -----------------------------------------------------------------------------
# Scheduled publishing cron secret (production only)
# -----------------------------------------------------------------------------
# A shared secret the external cron includes as `X-Cron-Secret: <value>` when
# hitting /api/payload-jobs/run. Required in production; a missing/mismatched
# header causes the endpoint to 403. Unused in dev (instrumentation.ts ticks
# the queue via an internal dev-only endpoint).
#
# Generate with: openssl rand -hex 32

# CRON_SECRET=replace-with-another-32-byte-random-hex-string

# Stripe Billing — OpenMasjid platform's own Stripe account (NOT Connect).
# Charges tenants $49/mo or $490/yr for use of the platform.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
# Where Stripe Customer Portal returns the user after managing their subscription.
STRIPE_BILLING_PORTAL_RETURN_URL=https://openmasjid.app/admin/billing

# Bearer token for /api/cron/billing-sweep. Generate with `openssl rand -hex 32`.
BILLING_SWEEP_TOKEN=

# Stripe Connect — tenant-owned donation accounts (Standard Connect).
# Each tenant connects their own Stripe account via OAuth; donations are
# charged directly on the tenant's account with no platform application fee.
#
# Client ID: Settings → Connect → Onboarding options → OAuth (test/live differ).
STRIPE_CONNECT_CLIENT_ID=ca_...
# Connect-mode webhook signing secret. Locally use `stripe listen --forward-connect-to
# localhost:3000/api/stripe/connect/webhook` and copy the printed whsec_... here.
# In production, register a webhook endpoint with "Listen to events from Connected
# accounts" enabled and use that endpoint's signing secret.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
